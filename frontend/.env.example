# Google Maps API Key
# Lấy tại: https://console.cloud.google.com/
# Cần enable: "Maps JavaScript API"
VITE_GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# Google Maps Map ID (tùy chọn)
# Tạo tại: Google Cloud Console > Google Maps Platform > Map Management
# Nếu không có, dùng "DEMO_MAP_ID" để test (có thể có giới hạn)
VITE_GOOGLE_MAPS_MAP_ID=DEMO_MAP_ID
